// Prisma schema for Kanban Board with AI Research Process Tracking

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================================================
// Core Kanban Models
// ============================================================================

model Column {
  id        Int     @id @default(autoincrement())
  name      String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@map("columns")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  columnId    Int
  position    Int
  phase       String   @default("implementation") // requirement | design | implementation | testing | deployment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  sessions    AISession[]
  artifacts   Artifact[]

  @@index([columnId])
  @@index([phase])
  @@map("tasks")
}

// ============================================================================
// AI Research Process Models
// ============================================================================

/// AI conversation sessions - tracks each AI-assisted development session
model AISession {
  id          Int      @id @default(autoincrement())
  title       String   // Session title/description
  phase       String   // requirement | design | implementation | testing | deployment
  taskId      Int?     // Link to kanban task if applicable
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  summary     String?  // Session summary/notes
  completed   Boolean  @default(false)
  metadata    String?  // JSON metadata (model used, tokens, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skillCalls  SkillCall[]
  artifacts   Artifact[]

  @@index([phase])
  @@index([taskId])
  @@map("ai_sessions")
}

/// Skill tool invocations - records each AI skill usage
model SkillCall {
  id          Int      @id @default(autoincrement())
  sessionId   Int      // Link to AI session
  session     AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  skill       String   // Skill name (e.g., "planner", "code-reviewer", "tdd")
  input       String?  // JSON input to the skill
  output      String?  // JSON output from the skill
  durationMs  Int?     // Execution time in milliseconds
  status      String   @default("success") // success | failed
  error       String?  // Error message if failed
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([skill])
  @@map("skill_calls")
}

/// Artifacts - documents and code files generated by AI
model Artifact {
  id          Int      @id @default(autoincrement())
  sessionId   Int      // Link to AI session
  session     AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  taskId      Int?     // Link to kanban task if applicable
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  type        String   // document | code | config | other
  name        String   // Display name
  path        String?  // File path if saved
  language    String?  // Programming language for code files
  content     String?  // File content (optional, can be large)
  version     Int      @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
  @@index([taskId])
  @@index([type])
  @@map("artifacts")
}

// ============================================================================
// Pipeline Events Models
// ============================================================================

/// Pipeline events - simulates CI/CD events via webhooks
model PipelineEvent {
  id          Int      @id @default(autoincrement())
  type        String   // commit | build | test | deploy
  status      String   // success | failed | running
  author      String?  // Author for commits
  message     String?  // Event message/description
  sha         String?  // Git commit SHA
  durationMs  Int?     // Duration for builds/tests
  error       String?  // Error message if failed
  metadata    String?  // JSON metadata for extended data
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([status])
  @@map("pipeline_events")
}
